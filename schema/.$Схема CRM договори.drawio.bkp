        <mxCell id="xLQqsGP4wDbx-OHAPbiL-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;fontSize=16;spacingLeft=5;" value="Товари&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;1. Назва товару&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;2. ПДВ % (за замовчуванням 20%, але з можливістю коригування&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;3. Ціна (без ПДВ) автоматично присвоюється (вираховується), якщо вказана ціна з ПДВ&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;4. Ціна (з ПДВ)&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;автоматично присвоюється (вираховується, якщо вказана ціна без ПДВ&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="410" x="570" y="810" as="geometry" />
        </mxCell>
