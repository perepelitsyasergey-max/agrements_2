        <mxCell id="xLQqsGP4wDbx-OHAPbiL-47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;fontSize=16;spacingLeft=5;" value="Користувачі:&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;1. Логін (емейл)&lt;/div&gt;&lt;div&gt;2. Пароль&lt;/div&gt;&lt;/div&gt;&lt;div&gt;3. Ім&#39;я&lt;/div&gt;&lt;div&gt;4. Статут (амін,юрист, бухгалтер, керівник, щоб надавати різні дозволи за статусами&lt;/div&gt;" vertex="1">
          <mxGeometry height="270" width="150" x="570" y="-770" as="geometry" />
        </mxCell>
        <mxCell id="xLQqsGP4wDbx-OHAPbiL-59" edge="1" parent="1" source="xLQqsGP4wDbx-OHAPbiL-56" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" target="xLQqsGP4wDbx-OHAPbiL-4">
