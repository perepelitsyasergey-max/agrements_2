        <mxCell id="4aPJvO8r1FB0Xj5YpUQw-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=5;" value="&lt;div style=&quot;font-size: 16px;&quot;&gt;Контакти:&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; 1. Тел.&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; 2. Ім&#39;я,&lt;/div&gt;&lt;div style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; 3. Посада&lt;/div&gt;" vertex="1">
